; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all documented.
;
; Format:
;   [section] ; section goes in []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Totopo Smash"
config/description="Lanza ráfagas de semillas desde tu molcajete y destruye filas de totopos y comida chatarra en este arcade de física hipercasual."
config/version="0.1.0"
run/main_scene="res://src/scenes/MainMenu.tscn"
config/quit_on_go_back=false
config/features=PackedStringArray("4.7", "Mobile")
config/icon="res://assets/icon.png"
boot_splash/image="res://assets/splash.png"
boot_splash/bg_color=Color(0.086, 0.106, 0.145, 1)
boot_splash/fullsize=false
boot_splash/use_filter=false

[autoload]

; CRITICAL: Constants must be FIRST — all other autoloads depend on it.
Constants="*res://src/core/Constants.gd"
EventBus="*res://src/core/EventBus.gd"
GameManager="*res://src/core/GameManager.gd"
SaveManager="*res://src/core/SaveManager.gd"
LevelManager="*res://src/core/LevelManager.gd"
LocalizationManager="*res://src/core/LocalizationManager.gd"
AudioManager="*res://src/features/audio/AudioManager.gd"
HapticManager="*res://src/features/audio/HapticManager.gd"

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[display]

window/size/viewport_width=390
window/size/viewport_height=844
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation=1

[input]

; Touch input for mobile — add game-specific actions here
ui_accept={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":4194309,"physical_keycode":0,"key_label":0,"unicode":32,"location":0,"echo":false,"script":null)
]
}

[input_devices]

; El Mortar solo escucha InputEventScreenTouch/Drag (GDD: control táctil de 1 dedo).
; Sin esto, mouse/trackpad en el editor de escritorio no generan esos eventos y
; apuntar/disparar no responde a nada (Godot no emula touch desde mouse por defecto).
pointing/emulate_touch_from_mouse=true

[layer_names]

; Physics layer naming (matches collision_mask usage in code)
2d_physics/layer_1="world"
2d_physics/layer_2="blocks"
2d_physics/layer_3="molcajete"
2d_physics/layer_4="seeds"
2d_physics/layer_5="pickups"

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
